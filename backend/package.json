  "description": "Backend for AI Assessment Creator using Express, TypeScript, Mongoose, BullMQ, and Socket.io",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts"
  },
  "dependencies": {
    "@google/genai": "^2.6.0",
    "bullmq": "^5.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "ioredis": "^5.4.1",
    "mongoose": "^8.3.1",
    "multer": "^1.4.5-lts.1",
    "pdfkit": "^0.15.0",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.12.7",
    "@types/pdfkit": "^0.13.4",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
